# EmbyD Configuration via Environment Variables
# Copy this file to .env and fill in your settings

# Emby Server URL (required)
EMBY_SERVER_URL=https://example.com

# Emby Username (required for login)
EMBY_USERNAME=test_user

# Emby Password (optional - will prompt if not set)
EMBY_PASSWORD=replace_me

# Download directory (default: ./downloads)
EMBY_DOWNLOAD_DIR=D:\EmbyDTestDownloads

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
EMBY_LOG_LEVEL=INFO
